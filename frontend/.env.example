# Lynx frontend env (all optional — sensible defaults baked in)

# Backend (Hono) base URL — the FROZEN HTTP API
NEXT_PUBLIC_BACKEND_URL=http://localhost:8787

# RPC for live on-chain reads (ENSIP-25 badge, compare-screen scores)
NEXT_PUBLIC_RPC_URL=http://127.0.0.1:8545

# World ID (optional). Set to enable the real IDKit Orb widget; without it the dev
# "Verify (mock human)" path is used.
# NEXT_PUBLIC_WORLD_APP_ID=app_xxxxxxxxxxxxxxxxxxxxxxxxx
# NEXT_PUBLIC_WORLD_ACTION=lynx-review
