# Lynx backend env (copy to .env). All values have safe defaults for the local demo.

# RPC for the local anvil chain (or Base for live path).
RPC_URL=http://127.0.0.1:8545

# Attestor private key. Default = anvil account[0] (public, dev only). NEVER use in prod.
ATTESTOR_PK=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Optional explicit contract addresses. If unset, read from shared/addresses.local.json.
# REVIEW_GATE=0x...
# REPUTATION_REGISTRY=0x...
# IDENTITY_REGISTRY=0x...

# Optional: real agent execution via Claude. If absent, a deterministic stub is used.
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-fable-5

# Optional: real World ID verification. If absent, the attestor uses the dev mock path.
# WORLD_APP_ID=app_staging_...
# WORLD_ACTION=lynx-review

# x402 payment metadata (shown in the 402 response).
X402_PAY_TO=0x0000000000000000000000000000000000000000
X402_ASSET=USDC
X402_NETWORK=base
X402_MAX_AMOUNT=50000

# Misc
PORT=8787
FREE_TRIALS=3
CORS_ORIGIN=http://localhost:3000

# --- Arc payment mode (Circle Arc testnet — "Best Agentic Economy" prize) -------
# PAYMENTS selects the /agents/:id/call pay path:
#   mock (default) — accepts any non-empty X-PAYMENT header (the existing local demo).
#   arc            — verifies a REAL USDC ERC-20 Transfer on Arc testnet (DIRECT settlement).
# PAYMENTS=arc also defaults the addresses file to shared/addresses.arc.json (chainId 5042002).
# PAYMENTS=arc
#
# Arc testnet RPC (also baked into addresses.arc.json by DeployArc). EIP-1559, chainId 5042002.
# ARC_RPC_URL=https://rpc.testnet.arc.network
# ARC_CHAIN_ID=5042002
# USDC on Arc testnet: BOTH the native gas token (18-dec) AND an ERC-20 (6-dec). asset for x402.
# ARC_USDC=0x3600000000000000000000000000000000000000
# x402 accepts[].network string for Arc (DIRECT path uses the human-readable form).
# ARC_NETWORK=arc-testnet
# Circle GatewayWallet on Arc testnet (EIP-712 verifyingContract; used by the Gateway layer).
# ARC_GATEWAY_WALLET=0x0077777d7EBA4688BDeF3E311b846F25870A19B9
# Per-call price in 6-dec USDC units. 10000 = $0.01 (a nanopayment). Reuses X402_MAX_AMOUNT.
# X402_MAX_AMOUNT=10000
#
# Faucet (the human funds wallets — you cannot): https://faucet.circle.com (Arc Testnet, 20 USDC/2h).
# Per-agent payTo lives in shared/addresses.arc.json (written by DeployArc; override at deploy
# time with PAYTO1/PAYTO2/PAYTO3). The deployer must hold faucet USDC — Arc pays gas in USDC.

# --- BigQuery leaderboard (Google Cloud prize) ---------------------------------
# GET /leaderboard ranks ERC-8004 agents over the bigquery-public-data.crypto_ethereum.logs
# public dataset. If GCP_PROJECT + GOOGLE_APPLICATION_CREDENTIALS are BOTH absent (or the
# query fails), the endpoint returns a clearly-labeled SAMPLE leaderboard (source:"sample")
# and never crashes. To run the live query, set both:
# GCP_PROJECT=your-gcp-project-id
# GOOGLE_APPLICATION_CREDENTIALS=/abs/path/to/service-account-key.json
# BIGQUERY_LOCATION=US
# Optional: tune the self-funded sybil cluster threshold (default 3).
# SYBIL_MIN_CLIENTS=3
